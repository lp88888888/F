	// 判断本次进入小程序是否需要展示「出行体验官」弹窗
	const checkExperiencePopup = async () => {
		console.log("---------checkExperiencePopup-------------");
	  // 未登录不弹（按需要保留 / 去掉）
	  if (!isLogin.value) {
		  showExperiencePopup.value = true;
		  return 
	  }
	
	  // 本次小程序生命周期已经判断过，就不再调接口
	  if (app.globalData.hasCheckExperiencePopup) {
	    return
	  }
	
	  // 立刻置为已判断，避免重复并发调用
	  app.globalData.hasCheckExperiencePopup = true
	
	  try {
	    const res: any = await shouldShow()
	    // 根据后端返回结构判断，这里假设后端返回 { code:200, data:true/false }
	    if (res.code === 200 && (res.data === true || res.data?.show)) {
	      // 打开弹窗
	      openExperiencePopup()
	
	      // 记录“本次已展示弹窗”
	      // data 结构按你后端约定来，这里示例一个最简的
	      await recordShow({
	        // 比如传一个弹窗业务编码，方便后端区分
	        popupCode: 'experience_officer'
	      })
	    }
	  } catch (e) {
	    console.error('出行体验官弹窗判断失败:', e)
	  }
	}
	
	
