	/* 文本截断（nvue 仅支持单行省略） */
	.tex-no-wrap {
		/* nvue 的单行文本溢出处理 */
		lines: 1;
		text-overflow: ellipsis;
	}
	/* nvue 无法实现多行文本省略，只能保证容器高度 */
	.g-line2, .s-line2 {
