<script setup lang="ts">
	import {
		ref,
		onMounted,
		computed,
		watch
	} from 'vue';
	import SateLayer from '@/components/SateLayer/index.nvue';
	import Recorder from '@/components/RecorderApp/RecorderApp.vue';
	import {
		getTadayApi,
	} from '@/api/weather.ts';
	import {
		getNewsList,
		recordShow,
		shouldShow
	} from '@/api/home';
	import { onLoad, onReady, onShow, onTabItemTap, onPageScroll } from "@dcloudio/uni-app"
	import { updateClickVolume, getLocationInfoid } from "@/api/index";
	import { makePhoneCall, openLocation } from '@/utils/util';
	import { toast } from "@/utils/common";
	import { imgUrl } from '../../config';
	import { toNav } from "@/utils/route";
	import { CurrentPage, showAlert2 } from '@/utils/util'
	import { useAppStore } from '@/store/modules/app';
	import { getByUserIdAndVehicleAll } from '@/api/user';
	import { useElementRects } from '@/utils/useElementRect';
	import { getPrSupplyRouteSubscription, listPrSupplySource } from '@/api/premium';
	import { getEvents, getgetTollStationByIdList, getgetServiceAreaPageList, getServiceAreaById } from '@/api/map';
	import {formatDate,splitTime} from "@/utils/date"
	
	const props = defineProps<{
		scrollTop : number
	}>()
	const sateLayerRef = ref(null);
	const recorderRef = ref(null);
	const { queryAll } = useElementRects(['#navID'])
	const topBoxHeight = ref(100);
	const appStore = useAppStore();
	// const isLogin = ref(appStore.checkLogin());
	const newArray = ref<any>([])
	const backgroundColor = ref<string>('#fff');
	const fixed = ref<boolean>(true);
	const isshow = ref<boolean>(true);
	const navBarHeight = ref(0);
	const bottomHeight = ref(100);
	const searchRead = ref(false);

	const longitude = ref(0);
	const latitude = ref(0);
	const keyword = ref('');
	const dataList = ref<any>([])
	const datObj = ref<any>({})
	const navBgColor = ref('#D7E1EB');
	const searchBgColor = ref('transparent');
	const cityDw = ref('');
	const inpBgColor = ref('rgba(255,255,255,.7)');
	// 主题 使用 （主题颜色 var( --theme-color)）（组件 componentColor.$pageBgColor） 图标地址（icoUrl）
	import { useTheme } from '@/composables/useTheme';
	const { themeStore, pageTheme } = useTheme();
	const icoUrl = ref(themeStore.imgUrl);
	// 监听themeStore.imgUrl的变化并更新icoUrl
	
	const orderLayer = ref({
		payStationName:'bndnd ',
		codeUrl:imgUrl+'dsewf.png'
		// codeUrl:''
	})
	const showOrder = ref(false);
	let inter = null;
	const splitDataTime = ref(splitTime(new Date()))
	const openTime=()=>{
		const intedr = setInterval(() => {
			splitDataTime.value = splitTime(new Date())
		}, 1000)
		inter = intedr
	}
	const closeOrederLayer = ()=>{
		showOrder.value = false
	}
	
	
	watch(
		[() => themeStore.imgUrl, () => props.scrollTop],
		([newImgUrl, top]) => {
			icoUrl.value = newImgUrl
			if (top > 20) {
				navBgColor.value = '#FFFFFF',
				inpBgColor.value='#EEEEEE';
			} else {
				navBgColor.value = '#D7E1EB'
				inpBgColor.value='rgba(255,255,255,.7)'
			}
		},
		{ immediate: true }
	)

	// 获取组件颜色
	const componentColor = themeStore.themeColors;
	const isLogin  = computed(()=>{
		return appStore.checkLogin()
	})
	//
	
	const lkTabs = computed(() => [
	  { name: '路况地图', icon: icoUrl.value + 'home-tab-icon1.jpg', type: '', route: '/pages_A/map/index' },
	  { name: '路况信息', icon: icoUrl.value + 'home-tab-icon2.jpg', type: '', route: '/pages_A/mapInfo/index' },
	  { name: '收费站查询', icon: icoUrl.value + 'home-tab-icon3.jpg', type: '', route: '/pages_A/toll/index' },
	  // {
	  //   name: '高速直播',
	  //   icon: icoUrl.value + 'home-tab-icon4.jpg',
	  //   type: 'appid',
	  //   route: 'https://gaoguantong.ruitong369.com/GaoGuanTongServer/gaoguantongHTML/html/direction/12122/MainTest.html?wxH5=1',
	  // },
	  {
	    name: '高速直播',
	    icon: icoUrl.value + 'home-tab-icon4.jpg',
	    type: '',
	    route: '',
	  },
	]);
	
	const fwTabs = computed(() => [
	  { name: '商超零售', icon: icoUrl.value + 'home-tab-icon5.jpg', type: '', route: '/pages_B/directRetail/index' },
	  { name: '餐饮美食', icon: icoUrl.value + 'home-tab-icon6.jpg', type: '', route: '/pages_B/dining/index' },
	  { name: '酒店住宿', icon: icoUrl.value + 'home-tab-icon7.jpg', type: '', route: '/pages_B/hotel/hotelist' },
	  { name: '汽车维修', icon: icoUrl.value + 'home-tab-icon8.jpg', type: '', route: '/pages_D/repair/carRepair' },
	]);
	
	const txTabs = computed(() => [
	  { name: 'ETC申办', icon: icoUrl.value + 'home-tab-icon9.jpg', text: '免费申办 包邮到家', type: 'appid', route: 'wxe442a27a2747b061' },
