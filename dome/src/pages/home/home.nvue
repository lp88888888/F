		<up-popup :show="versionShow" bgColor="transparent" mode="center" round="10">
			<view>
				<view class="gxBox">
					<image class="gxBox-bg" :src="imgUrl + 'gxPress-bg1.png'" :lazy-load="true" mode=""></image>
					<view class="gxBox-Item">
