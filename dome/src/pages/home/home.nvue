						</view>
						<view class="gxBox-Item-button">
							<view class="progressBox" style="margin-bottom: 30rpx">
								<view class="progressBox-item"
									:style="{ background: themeStore.themeColors.$primaryColor, width: percWidth + 'rpx' }">
								</view>
								<text class="progressBox-text">{{ formatNumber(percentage * 100) || 0 }}/100</text>
							</view>
							<text class="gxBox-Item-button-1" @click="downloadClick">立即更新</text>
