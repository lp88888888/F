						</view>
					</view>
				</view>
				<view class="closeBox">
					<up-icon name="close-circle" color="#FFFFFF" size="32" @click="versionShow = false"></up-icon>
				</view>
			</view>

			<!-- <view class="verBox">
				<view>
					<text class="verBox-title">有新版本：{{verData.versionName}}</text>
					<text class="verBox-text" v-if="verData.updateContent">更新内容：{{verData.updateContent}}</text>
				</view>
				<view class="verBox-bot">
					<view class="progressBox">
						<view class="progressBox-item" :style="{background:themeStore.themeColors.$primaryColor,width:percWidth+'rpx'}"></view>
						<text class="progressBox-text">{{ formatNumber(percentage * 100) || 0}}/100</text>
					</view>
					<text class="verBox-button" :style="{background:themeStore.themeColors.$primaryColor}" @click="downloadClick">更新</text>
				</view>
			</view> -->
		</up-popup>
		<!-- 模型下载弹窗 -->
		<up-popup :show="manShow" bgColor="transparent" mode="center" round="10">
			<view>
				<view class="gxBox">
					<image class="gxBox-bg" :src="imgUrl + 'gxPress-bg2.png'" mode="" :lazy-load="true"></image>
					<view class="gxBox-Item">
						<view class="gxBox-Item-Center">
							<text class="gxBox-Item-title">请下载数字人资源包，{{ modulText }}</text>
						</view>
						<view class="gxBox-Item-button" style="bottom: 90rpx">
							<view class="progressBox" style="margin-bottom: 30rpx">
								<view class="progressBox-item"
									:style="{ background: themeStore.themeColors.$primaryColor, width: manPercWidth + 'rpx' }">
								</view>
								<text class="progressBox-text">{{ manPress || 0 }}/100</text>
							</view>
							<text class="gxBox-Item-button-1" @click="downloadDmModel">立即下载</text>
							<!-- <text class="gxBox-Item-button-2" @click="manShow = false">下次再说</text> -->
						</view>
					</view>
				</view>
				<view class="closeBox">
					<up-icon name="close-circle" color="#FFFFFF" size="32" @click="manShow = false"></up-icon>
				</view>
			</view>
		</up-popup>

		<!-- 新人礼 -->
		<homePopup :show="xrlshow" :bg="userType == 1 ? `${imgUrl}static/home_xrl.png` : `${imgUrl}static/home_sjl.png`"
			:btnBg="imgUrl + 'static/home_sjl_btn.png'" width="540rpx" height="1000rpx" btnWidth="296rpx"
			btnHeight="88rpx" btnLeft="122rpx" @confirm="receiveGiftFun" @close="receiveGiftFun">
		</homePopup>
		<!-- 新人礼 - 查看 -->
		<homePopup :show="xrlCardshow" :bg="imgUrl + 'static/home_sjl_view.png'"
			:btnBg="imgUrl + 'static/home_sjl_view_btn.png'" width="710rpx" height="1120rpx" btnWidth="384rpx"
			btnHeight="100rpx" btnLeft="163rpx" @confirm="xrlCardshow = false" @close="xrlCardshow = false">
			<view class="content-card" style="left: 116rpx">
				<scroll-view scroll-y :style="{ height: scrollHeight }">
					<view v-for="(item, index) in couponList" class="coupon-bar">
						<image class="coupon-bar-bg" :src="imgUrl + 'static/home_view_carrd_bg.png'" mode=""></image>
						<view class="coupon-bar-box">
							<view class="coupon-left">
								<!-- <text class="coupon-num">50</text> 
							<text class="coupon-unit">元</text> -->
								<text class="coupon-title u-line-1">{{ item.name }}</text>
							</view>
							<view class="coupon-box-right">
								<text @click="toNav('/pages_C/coupon/index')" class="coupon-right">立即查看</text>
							</view>
						</view>
					</view>
					<view class="coupon-bar">
						<image class="coupon-bar-bg" :src="imgUrl + 'static/home_view_carrd_bg.png'" mode=""></image>
						<view class="coupon-bar-box">
							<view class="coupon-left">
								<text class="coupon-title">获得积分</text>
								<text class="coupon-num">{{ givePoints || 0 }}</text>
							</view>
							<view class="coupon-box-right">
								<text @click="toRec('/pages_A/pointslist/index')" class="coupon-right">立即查看</text>
							</view>
						</view>
					</view>
				</scroll-view>

				<text class="coupon-content">
					新人礼领取成功！{{ givePoints || 0 }}积分已存入您的积分账户可以前往积分商城兑换喜欢的礼品~加油券包可前往【我的】【我的卡券】中使用哦~
				</text>
			</view>
		</homePopup>
		<!-- 积分季 -->
		<homePopup v-model:show="jfjshow" :bg="`${imgUrl}static/home_jfj.png`"
			:btnBg="imgUrl + 'static/home_jfj_btn.png'" width="750rpx" height="1000rpx" btnWidth="372rpx"
			btnHeight="178rpx" btnLeft="189rpx" @confirm="jfjshow = false" @close="jfjshow = false">
			<view class="content-card">
				<view class="jfj-content">
					<view class="jfj-content-tetx">
						<text class="jfj-title">绑车即可得</text>
						<text class="fs-48 jfj-titl2">{{ jfjData.doublePointsRuleName }}</text>
						<text class="jfj-title">里程积分！</text>
					</view>
					<scroll-view class="m-t-100" scroll-y :style="{ height: scrollHeight1 }">
						<text class="jfj-text">规则：</text>
						<text class="jfj-text"> 平台上线2个月内里程积分{{ jfjData.doublePointsRuleName }}发放，其余积分不变。 </text>
						<text class="jfj-text fs-20 col3 fw-500">
							活动时间{{ jfjData.activityStartTime }}-{{ jfjData.activityEndTime }} 可在“我的”积分明细中查看详细积分记录哦~
						</text>
					</scroll-view>
				</view>
			</view>
		</homePopup>
	</view>
</template>
<script setup lang="ts">
	import { ref, onMounted,computed,watch } from 'vue';
	import { onLoad, onReady, onShow, onHide, onTabItemTap, onPageScroll } from '@dcloudio/uni-app';
	import { requestMicrophonePermission, permission } from '@/utils/usePermission';
	import OpenAiHuman from '@/components/OpenAiHuman/OpenAiHuman.nvue';
	import BdDigitalManBridge from '@/components/BdDigitalManBridge.nvue';
	import homePopup from './components/homePopup.nvue';
	const tabbarType = ref('');
	import IndexPage from './index.nvue';
	import MinePage from '@/pages/individual/individual.nvue';
	import PointsPage from '@/pages/points/index.nvue';
	import ServicePage from '@/pages/service/index.nvue';
	import oldIndex from '@/pages_E/oldindex/index.nvue';
	import redIndex from '@/pages_E/redindex/index.nvue';
	import { toNav, toRec } from '@/utils/route';
	import { getLocation,getAddress } from '@/utils/util';
	import { getThemeData } from '@/api/config';
	import { checkGiftType, receiveGift, recordIntegral, getredindex } from '@/api/home';
	import { getByUserIdAndVehicleAll, recordPasswordChangeShow, shouldShowPasswordChange } from '@/api/user';
	import { ChatStore } from '@/store/modules/chat';
	// 主题 使用 （主题颜色 var( --theme-color)）（组件 componentColor.$pageBgColor） 图标地址（icoUrl）
	import { useTheme } from '@/composables/useTheme';
	import { getCheckVersion } from '@/api/config';
	import { toast } from '@/utils/common';
	import { imgUrl } from '@/config';
	import { geoconvLab, reverseGeocoding } from '@/api/address';
	import { useMqttStore } from '@/store/modules/mqtt';
	import { useThemeStore } from '@/stores/theme';
	import { getMiniUserInfo } from '@/api/login';
	import { useAppStore } from '@/store/modules/app';
	import { jpushService } from '@/utils/jpush';
	const bdMapPlugin = uni.requireNativePlugin('bdMapPlugin');
	const appStore = useAppStore();
	const mqttStore = useMqttStore();
	const bdDigitalManPlugin = uni.requireNativePlugin('bdDigitalManPlugin');
	const versionShow = ref(false);
	const percentage = ref(0); // 下载进度
	
	// 适老版
	const oldpersondata = computed(() => {
		console.log('有没有适老版的缓存', uni.getStorageSync('oldperson'));
		return uni.getStorageSync('oldperson');
	});

	// 人像资源
	const manShow = ref(false);
	const modulText = ref('');
	const manPress = ref(0);
	const manPercWidth = computed(() => {
		const tatle = manPress.value / 100;
		return (tatle * 490).toFixed(2);
	});
	const percWidth = computed(() => {
		return (percentage.value * 490).toFixed(2);
	});
	const safeAreaInsetsBottom = computed(() => {
		console.log('安全距离下部', uni.getSystemInfoSync().safeAreaInsets.bottom);
		return uni.getSystemInfoSync().safeAreaInsets.bottom;
	});

	const chatStore = ChatStore();
	const bdSpeechPlugin = uni.requireNativePlugin('bdSpeechPlugin');
	const { themeStore, pageTheme } = useTheme();
	const icoUrl = ref(themeStore.imgUrl);
	const scrollTop = ref(1);
	const show = ref(false);
	const openHuman = ref(null);
	const bdDigitalManGlobal = ref(null);
	const indexRef = ref(null);

	const initMan = async () => {
		if (bdDigitalManGlobal.value) {
			const hasModel = await getModul(false);
			if (hasModel) {
				bdDigitalManGlobal.value.init({}, (res) => {
					console.log('---bdDigitalManGlobal init success---', res);
				});
			} else {
				console.log('---bdDigitalManGlobal model not found, skipping init---');
			}
		}
	};

	const bdDigitalStyleGlobal = computed(() => {
		if (show.value) {
			// AI 对话框显示时，隐藏
			return {
				width: '10rpx',
				height: '10rpx',
				position: 'absolute',
				top: '-999rpx',
				left: '-999rpx',
			};
		} else {
			// 首页时，隐藏
			return {
				width: '10rpx',
				height: '10rpx',
				position: 'absolute',
				top: '-999rpx',
				left: '-999rpx',
			};
		}
	});

	watch(bdDigitalManGlobal, (newVal) => {
		if (newVal) {
			console.log('---bdDigitalManGlobal ready---');
			initMan();
			if (indexRef.value) {
				indexRef.value.setBdDigitalMan(newVal);
			}
		}
	});

	watch(indexRef, (newVal) => {
		if (newVal && bdDigitalManGlobal.value) {
			newVal.setBdDigitalMan(bdDigitalManGlobal.value);
		}
	});

	watch(openHuman, (newVal) => {
		if (newVal && bdDigitalManGlobal.value) {
			newVal.setBdDigitalMan(bdDigitalManGlobal.value);
		}
	});

	const verData = ref({});
	const isLogin = computed(() => {
		return appStore.checkLogin();
	});
	
	onPageScroll((e) => {
		scrollTop.value = e.scrollTop;
		// console.log('距离home', e.scrollTop)
	});

	// 监听themeStore.imgUrl的变化并更新icoUrl
	watch(
		() => themeStore.imgUrl,
		(newVal) => {
			icoUrl.value = newVal;
		}
	);
	const getUserInfo = async () => {
		const res = await getMiniUserInfo();
		console.log('用户信息', res);
		appStore.updateUserInfo(res.clazz);
	};
	// 获取组件颜色
	const componentColor = themeStore.themeColors;
	const changeTab = async (type : string) => {
		if (type == 'allAdd') {
			if(!isLogin.value){
				uni.showToast({ title: '登录后使用，请先登录', icon: 'none' });
			}else{
				// console.log(uni.getSystemInfoSync());
				// return
				// #ifdef MP-WEIXIN || APP-HARMONY
				toNav('/pages_E/digitalHuman/index');
				// #endif
				// #ifdef APP-PLUS
				const hasPermission = await checkRecordAuth();
				const result = await getModul();
				if (!result || !hasPermission) {
				} else {
					toNav('/pages_E/digitalHuman/openAi');
					// toNav('/pages_E/digitalHuman/address');
				}
				// toNav('/pages_E/digitalHuman/openAi');
				// toNav('/pages_E/digitalHuman/address');
			}
			

			// #endif
		} else {
			tabbarType.value = type;
		}
		getpagecolorval()
	};

	const xrlshow = ref(false);
	const xrlCardshow = ref(false);
	const jfjshow = ref(false);
	const bgStyle = computed(() => ({
		width: '490rpx',
		height: '160rpx',
		margin: '0 auto',
		padding: '0 42rpx',
		boxSizing: 'border-box',
		backgroundImage: `url(${imgUrl + 'static/home_view_carrd_bg.png'})`,
		backgroundSize: '100% 100%',
		backgroundRepeat: 'no-repeat',
		backgroundPosition: 'center',
	}));
	const scrollHeight = ref('340rpx');
	const scrollHeight1 = ref('200rpx');
	const couponList = ref([]);
	const givePoints = ref(0);
	const userType = ref('');
	const isExternal = ref(false);
	const checkGiftTypeFun = async () => {
		const userInfo = uni.getStorageSync('userInfo').id;
		if (!userInfo) return;
		const params = {
			sourcePlatform: 1,
		};

		try {
			const res : any = await checkGiftType(isExternal.value ? params : {});
			console.log('app新人礼弹窗v', res);
			if (res.data.userType == 1 || res.data.userType == 2) {
				xrlshow.value = true;
			}
			userType.value = res.data.userType;
		} catch (err) {
			console.log('-------------------isExternal-err---------------------', res);
		}
	};
	const receiveGiftFun = async () => {
		const userInfo = uni.getStorageSync('userInfo').id;
		if (!userInfo) return;
		xrlshow.value = false;
		const res : any = await receiveGift({ giftType: Number(userType.value) });
		// const res: any = await receiveGift({ giftType: Number(1) });
		if (res.code == 200) {
			xrlCardshow.value = true;
			couponList.value = res.data.giftCouponList;
			givePoints.value = res.data.givePoints;
		}
	};
	const jfjData = ref({});
	// 积分
	const recordIntegralFun = async () => {
		const userInfo = uni.getStorageSync('userInfo').id;
		if (!userInfo) return;
		const res : any = await recordIntegral();
		if (res.code == 200 && res.data) {
			jfjshow.value = true;
			jfjData.value = res.data;
		}
	};

	async function checkRecordAuth(type=true) {
		console.log('-------1----------');
		const platform = uni.getSystemInfoSync().platform;
		let granted = false;
		console.log('-------2----------', platform);
		if (platform === 'android') {
			// 麦克风权限
			try {
				const PackageManager = plus.android.importClass("android.content.pm.PackageManager");
				const main = plus.android.runtimeMainActivity();
				const ContextCompat = plus.android.importClass("androidx.core.content.ContextCompat");
				let resuelt = ContextCompat.checkSelfPermission(main, 'android.permission.RECORD_AUDIO');
				// objPrt.isMicOpen = (resuelt === PackageManager.PERMISSION_GRANTED);
				if(resuelt === PackageManager.PERMISSION_GRANTED){
					console.log('-0-0-0-0-0-0--0-0--00--0,1111');
					granted = true;
				}else{
					if(type){
						const result = await permission.requestAndroidPermission('android.permission.RECORD_AUDIO');
						granted = result === 1; // 1 允许  0 拒绝  -1 永久拒绝
					}
					console.log('-0-0-0-0-0-0--0-0--00--0,2222');
				}
			} catch {
				if(type){
					const result = await permission.requestAndroidPermission('android.permission.RECORD_AUDIO');
					granted = result === 1; // 1 允许  0 拒绝  -1 永久拒绝
				}
				console.log('-0-0-0-0-0-0--0-0--00--0,44444');
			}
			
		} else if (platform === 'ios') {
			granted = permission.judgeIosPermission('record');
		}

		if (!granted) {
			// uni.showToast({ title: '未获取麦克风权限，需手动开启', icon: 'none' });
			// uni.showModal({
			// 	title: '需要麦克风权限,用于唤醒小猴',
			// 	content: '是否前往设置手动开启？',
			// 	success: (res) => res.confirm && permission.gotoAppPermissionSetting(),
			// });
		}
		return granted;
	}
	const openAiHuman = async () => {
		console.log('----------------openAiHuman------------------');
		// 空的
		const hasPermission = await checkRecordAuth();
		const result = await getModul(true);
		if (!result) return
		if (!hasPermission) {
			// uni.showToast({ title: '未获取麦克风权限', icon: 'none' });
			return;
		} else {
			stopWakeUp();
			show.value = true;
		}
	};
	const startWakeUp = async () => {
		if (show.value) return;
		console.log('=====');
		const hasPermission = await checkRecordAuth(false);
		const result = await getModul(false); 
		console.log('-=-=', hasPermission);
		if (!hasPermission) {
			// uni.showToast({ title: '未获取麦克风权限', icon: 'none' });
			return;
		} else {
			if (!result) return
			if (!result) return uni.showToast({ title: '请先下载数字人资源包', icon: 'none' });
			bdSpeechPlugin.startWakeUp((res) => {
				res = JSON.parse(res);
				console.log('唤醒===', res);
				if (res.code == 0) {
					stopWakeUp();
					show.value = true;
					console.log('0-----', show.value);
				}
				if (res.code == 3 || res.code == 1) {
					// getPermission();
				}
			});
		}
	};
	const stopWakeUp = () => {
		bdSpeechPlugin.stopWakeUp((res) => {
			console.log('语音唤醒停止收到的回调： ', res);
		});
	};
	const getPermission = async () => {
		console.log('-----2------');
		const hasPermission = await checkRecordAuth();
		console.log('-----------', hasPermission);
		if (!hasPermission) {
			uni.showToast({ title: '未获取麦克风权限', icon: 'none' });
			return;
		}
	};

	const close = () => {
		show.value = false;
		if (bdDigitalManGlobal.value) {
			bdDigitalManGlobal.value.interrupt();
		}
		setTimeout(() => {
			startWakeUp();
		}, 300);
	};
	const getVersion = async () => {
		const systemInfo = uni.getSystemInfoSync();
		const appVersion = systemInfo.appWgtVersion || systemInfo.appVersion;
		const appVersionCode = systemInfo.appVersionCode || systemInfo.appVersionCode;
		console.log('------------', appVersionCode);
		console.log('-------------getVersion-----------', systemInfo);
		try {
			let res = await getCheckVersion(appVersionCode);
			console.log('更新', res);
			if (res.code == 200) {
				if (res.data) {
					versionShow.value = true;
					verData.value = res.data;
				}
			} else {
				toast(res.msg);
			}
		} catch (err) {
			console.log('-------------err-----------------', err);
		}
	};
	const downloadClick = () => {
		const url = verData.value.packagePath;
		const type = verData.value.packagePath.indexOf('.wgt') == -1 ? 'apk' : 'wgt';
		const isWgt = type === 'wgt';

		// uni.showLoading({
		//     title: '下载中...'
		// })
		if (verData.value.fileSize) {
			startDownload(url, isWgt);
		} else {
			// 先获取文件信息
			uni.request({
				url: url,
				method: 'HEAD',
				success: (res) => {
					if (res.statusCode === 200) {
						const fileSize = parseInt(res.header['Content-Length']);
						console.log('----------fileSize----------', fileSize);
						if (fileSize > 0) {
							verData.value.fileSize = fileSize;
							startDownload(url, isWgt);
						} else {
							uni.hideLoading();
							uni.showToast({
								title: '无法获取文件大小',
								icon: 'none',
							});
						}
					} else {
						uni.hideLoading();
						uni.showToast({
							title: '文件信息获取失败',
							icon: 'none',
						});
					}
				},
				fail: () => {
					uni.hideLoading();
					uni.showToast({
						title: '网络请求失败',
						icon: 'none',
					});
				},
			});
		}
	};

	const startDownload = (url : string, isWgt : boolean) => {
		// versionShow.value = false;
		let dtask = plus.downloader.createDownload(url, {}, (d, status) => {
			if (status == 200) {
				uni.hideLoading();
				plus.runtime.install(
					d.filename,
					{
						force: false,
					},
					() => {
						console.log('安装成功');
						if (isWgt) {
							plus.runtime.restart();
						} else {
							plus.runtime.quit();
						}
					},
					(e) => {
						console.log('安装失败', e);
						uni.showModal({
							content: e.message,
							showCancel: false,
						});
					}
				);
			} else {
				uni.hideLoading();
				uni.showToast({
					title: '下载失败',
					icon: 'none',
				});
				plus.downloader.clear();
			}
		});

		dtask.addEventListener('statechanged', (task) => {
			if (!dtask) return;
			switch (task.state) {
				case 1:
					console.log('开始下载');
					break;
				case 2:
					console.log('连接到服务器...');
					break;
				case 3:
					const progress = task.downloadedSize / verData.value.fileSize;
					percentage.value = progress;
					console.log('下载进度：' + formatNumber(progress, 2) + '%');
					break;
				case 4:
					console.log('下载完成');
					break;
			}
		});

		dtask.start();
	};

	const formatNumber = (num : number, decimals : number = 2) => {
		if (isNaN(num)) return '0';
		const str = num.toString();
		const index = str.indexOf('.');
		if (index === -1) {
			return str + '.' + '0'.repeat(decimals);
		}
		const decimal = str.substring(index + 1);
		if (decimal.length < decimals) {
			return str + '0'.repeat(decimals - decimal.length);
		}
		return str.substring(0, index + decimals + 1);
	};

	const carNumber = ref('');
	const getcarData = async () => {
		try {
			const userId = uni.getStorageSync('userInfo')?.id;
			if (!userId) return;
			const params = {
				userId: userId,
			};
			const res : any = await getByUserIdAndVehicleAll(params);
			carNumber.value = res.data[0] ? res.data[0].licensePlate : '请绑定车辆';
			uni.setStorageSync('carNumber', carNumber.value);
		} catch (e) {
			carNumber.value = '请绑定车辆';
		}
	};
	const geoconvLabAd = async (logAndlat) => {
		let res = await geoconvLab(logAndlat);
	};
	// 逆地理解析
	const getAdddress = () => {
		bdMapPlugin.getCurrentLocation((event) => {
			console.log('当前位置', JSON.parse(event));
			const res = JSON.parse(event);
			if (res.z) {
				const result = res.z;
				let address = {
					lat: res.c,
					lng: res.d,
					city: result.city,
					cityCode: result.adcode.substring(0, 4) + '00',
					province: result.province,
					provinceCode: result.adcode.substring(0, 2) + '0000',
					district: result.district,
					districtCode: result.adcode,
					standardAddress: result.address,
				};
				uni.setStorageSync('address', address);
			}
		});
	};
	const getPass = async () => {
		try {
			let res = await shouldShowPasswordChange();
			if (res.code == 200) {
				if (res.data) {
					uni.showModal({
						title: '提示',
						content: '是否去设置新密码？',
						cancelText: '取消',
						confirmText: '确定',
						success: function (ress) {
							if (ress.confirm) {
								toNav('/pages_E/passwordSettings/index');
							} else if (ress.cancel) {
							}
						},
					});
					await recordPasswordChangeShow();
				}
			}
		} catch (err) { }
	};
	// 查询模型是否加载
	const getModul = (type = true) => {
		return new Promise((resolve, reject) => {
			bdDigitalManPlugin.checkDigitalManModelFile((res) => {
				console.log('检查数字人模型文件：', res);
				res = JSON.parse(res);
				console.log('-0--0---0-00-------', type);
				if (res.code != 0) {
					if (type) {
						manPress.value = 0;
						manShow.value = true;
						modulText.value = res.msg;
					}

					resolve(false);
				} else {
					resolve(true);
				}
			});
		});
	};
	// 模型下载
	const downloadDmModel = () => {
		const url = 'https://tranalioss.shanyitong.com/tongyipingtai/images/app-static/BdDigitalMan/case/case-coco-20251128.zip';
		// manShow.value = false;

		bdDigitalManPlugin.downloadDigitalManModel(url, (res) => {
			const obj = JSON.parse(res);
			if (obj.code == 12) {
				manPress.value = obj.data;
			}
			if (obj['code'] === 0) {
				manShow.value = false;
				uni.showToast({
					title: '数字人模型下载成功',
				});
				initMan();
				startWakeUp();
				// manShow.value = false;
			}
			console.log('下载数字人模型：  ', obj);
		});
	};

	// 吉祥物数据
	const themeInfoList = ref({
		cardImg: 'https://services.sxjk-cloud.com:32570/test/38bf9498-37c4-4d63-8da0-03b0edcbd78b.png',
		description: '小主～快选我做你的专属吉祥物呀～',
		id: '2009594965780353026',
		isDefault: 1,
		mascotBtn: 'https://services.sxjk-cloud.com:32570/test/44018a99-5522-4c55-95ca-6e8d210685ea.png',
		mascotGit: 'https://services.sxjk-cloud.com:32570/test/7d9ef8be-34ad-4c73-aa38-16cfee873aa7.gif',
		mascotIcon: 'https://services.sxjk-cloud.com:32570/test/9cb18e21-cbc3-4f56-b551-23bd52c75a9d.png',
		name: '金丝猴·金灵捷卡',
	});
	const vipCardType = ref(0);
	// 查询主题数据
	const getThemeinfo = async () => {
		try {
			const res = await getThemeData();
			console.log('我的页面查询的主题', res);
			const list = res.data.list;
			if (list.length) {
				uni.setStorageSync('themlist', list);
				if (typeof uni.getStorageSync('vipCardType') === 'number') {
					vipCardType.value = uni.getStorageSync('vipCardType');
				} else {
					vipCardType.value = list.findIndex((e) => e.isDefault === 1);
					uni.setStorageSync('vipCardType', vipCardType.value);
				}
				themeInfoList.value = list[vipCardType.value || 0];
			}
		} catch (err) {
			console.log('查询主题数据报错了', err);
			uni.setStorageSync('themlist', [themeInfoList.value]);
			uni.setStorageSync('vipCardType', 0);
		}
	};
	const isExternalLinkSimple = (url : string) : boolean => {
		if (!url) return false;
		const s = String(url).trim().toLowerCase();
		return s.startsWith('http://') || s.startsWith('https://') || s.startsWith('//');
	};
	
	onLoad((options) => {
		jpushService.completeInit((res) => {
		  console.log('JPush Event:', res.eventName, res.eventData);
		});
		
		bdMapPlugin.initBdMap()
		// 清空上次未登录401缓存
		uni.removeStorageSync('oldShowModel');
		console.log(options.type);
		uni.$on('updatevipcardtype', (data) => {
			console.log('监听到事件来自 update ，携带参数 msg 为：', data);
			themeInfoList.value = uni.getStorageSync('themlist')[data.index];
		});
		const link = options?.link || '';
		console.log('监听到link', link);
		if (isExternalLinkSimple(link)) {
			isExternal.value = true;
		} else {
			isExternal.value = false;
		}
		if (options.type) {
			tabbarType.value = options.type;
		} else {
			tabbarType.value = 'index';
		}
		getVersion();
		// getModul();
		
		
		if(uni.getStorageSync('userInfo')?.id){
			getAddress()
			jpushService.setAlias(uni.getStorageSync('userInfo')?.id*1,uni.getStorageSync('userInfo')?.id)
		}else{
			if(!uni.getStorageSync('address')){
				let address = {
					lat: 34.2778,
					lng: 108.953098,
					city: '西安市',
					cityCode: '610100',
					province: '陕西省',
					provinceCode: '610000',
					district: '雁塔区',
					districtCode: '610104',
					standardAddress:"陕西省西安市雁塔区"
				};
				uni.setStorageSync('address', address);
			}
		}
		
	});
	
	// 获取红色状态  1: 红色首页  0：正常页面
	const redpagestatus = ref('0')
	const getpagecolorval = async () =>{
		try{
			const res = await getredindex()
			redpagestatus.value = res.data
			console.log("查询的红色状态",res)
		}catch(err){
			redpagestatus.value = "0"
		}
	}
	
	onShow(() => {
		checkGiftTypeFun();
		recordIntegralFun();
		getThemeinfo();
		
		if (uni.getStorageSync('userInfo')?.id) {
			getUserInfo();
			getPass();
			// mqttStore.initMqtt()
			// getcarData();
		}
		startWakeUp();
		chatStore.getConfig();
		getpagecolorval();
		appStore.fetchOnlineData()
	});
	onHide(() => {
		uni.$off('updatevipcardtype');
		// 	console.log("----onHide----");
		show.value = false;
		if (bdDigitalManGlobal.value) {
			bdDigitalManGlobal.value.interrupt();
		}
		stopWakeUp();
	});
</script>

