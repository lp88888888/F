				}
				.fixedView-inputs-item-img2{
					width: 50rpx;
					height: 50rpx;
				}
				.fixedView-inputs-item-icon {
					// position: absolute;
					left: 30rpx;
					top: 23rpx;
				}
	
				.fixedView-inputs-item-text {
					width: 100%;
					display: block;
					text-align: center;
					font-weight: bold;
