		justify-content: space-between;
	}
	.fixedView {
		width: 750rpx;
		position: absolute;
		bottom: 0;
		left: 0;
		z-index: 9;
		background-color: transparent !important;
		
		.fixedView-card {
			width: 750rpx;
			
			padding: 20rpx 30rpx 50rpx 30rpx;
			box-sizing: border-box;
			flex-direction: row;
