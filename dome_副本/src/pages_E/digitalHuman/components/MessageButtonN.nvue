			.fixedView-inputs {
				width: 686rpx;
				min-height: 112rpx;
				flex-direction: row;
				align-items: center;
				justify-content: space-between;
				

				.fixedView-inputs-item {
					width: 686rpx;
					min-height: 112rpx;
					background: #FFFFFF;
					border-radius: 44rpx;
					flex-direction: row;
					align-items: center;
