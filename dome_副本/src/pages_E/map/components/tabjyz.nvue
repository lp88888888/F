<template>
	<view class="container" style="height: 800rpx;  box-sizing: border-box;">
		<!-- 标题区域 -->
		<view class="header">
			<view class="title">
				<view style="flex-direction: row;align-items: center;">
					<text class="title-text">沿途共计</text>
					<text class="count">{{fwqlist.length}}</text>
					<text class="title-text">个收费站</text>
				</view>
				<u-icon name="close" color="#000" size="24" @click="onClose"></u-icon>
			</view>
			<!-- 状态标签列表 -->
			<view class="tag-list">
				<text v-for="item in invoiceList " :key="item.id" class="tag" :class="{ active: item.id === activeTag }" @click="chengtags(item.id)">
					{{ item.rkname }}
				</text>
			</view>
		</view>
		<scroll-view scroll-y="true" style="flex: 1;background-color:  #EFF1F6;" :show-scrollbar="false">
			<view v-for="item in fwqlist " :key="item.id" class="station-item">
				<image v-if="item?.detailList" :src="item?.detailList[0]?.serviceInfoPicUrl" mode="aspectFill" class="bg-img"></image>
				<image src="https://tranalioss.shanyitong.com/images/20230225/1677317200274.jpeg" v-else mode="aspectFill" class="bg-img"></image>
				<view class="content">
					<view class="row">
						<text class="name">{{ item.tollStationName }}</text>
						<image :src="imgUrl+'img/daohang.png'" mode="aspectFill" class="icon"></image>
					</view>
					<text class="distance">{{item.distance}}</text>
					<text class="address texNoWrap2">{{ item.tollStationAddress }}</text>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script setup lang="ts">
	import { ref, reactive,onMounted } from 'vue'
	import { imgUrl } from '../../../config';
	import {
		getTollStationByLngLatList
	} from '@/api/map';
	const props = defineProps({
		fromcurrentLat: {
			type: String,
			default: '',
		},
		fromcurrentLng: {
			type: String,
			default: '',
		},
		tolatitude: {
			type: String,
			default: '',
		},
		tolongitude: {
			type: String,
			default: '',
		}
	});
	const pageNum = ref(1)
	// 页面显示
	onMounted(() => {
		getlist()
	})
	const chengtags = (id) => {
		activeTag.value = id
		getlist()
	}
	const getlist = async () => {
		const params = {
			pageNum: pageNum.value,
			pageSize: 10,
			myLongitude: props.fromcurrentLng,
			myLatitude: props.fromcurrentLat,
			startLongitude: props.fromcurrentLng,
			startLatitude: props.fromcurrentLat,
			endLongitude: props.tolongitude,
			endLatitude: props.tolatitude,
			operationalStatus: activeTag.value
		};
		const wealiat = await getTollStationByLngLatList(params)
		console.log(wealiat);
		fwqlist.value = wealiat?.page.records
	};
	// 标签列表
	const invoiceList = ref([
		{ id: "01", rkname: '全部' },
		{ id: "02", rkname: '正常' },
		{ id: "03", rkname: '关闭' },
		{ id: "05", rkname: '管制' }
	])

	// 收费站列表
	const fwqlist = ref([

	])

	// 当前选中标签
	const activeTag = ref('01')

	// 关闭事件
	const emit = defineEmits<{
		(e : 'call-parent', data : string) : void
	}>()

	// 关闭事件
	const onClose = () => {
		emit('closetab')
	}
</script>

<style scoped lang="scss">
	.container {
		height: 800rpx;
		position: relative;
		background: #EFF1F6;
		border-radius: 36rpx 36rpx 0rpx 0rpx;
		border: 3px solid #FFFFFF;
	}

	.header {
		flex-shrink: 0; /* 防止收缩 */
		padding: 20rpx;
