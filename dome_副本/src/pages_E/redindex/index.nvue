// 福利信息
.card_goods_list {
	width: 654rpx;
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 33rpx;

	.card_goods_item {
		width: calc(654rpx / 4 - 10rpx);
		flex-direction: column;
		align-items: center;

		.card_goods_item_img {
			width: calc(654rpx / 4 - 10rpx);
			height: 164rpx;
			align-items: center;
			justify-content: center;

			.card_goods_item_img_1 {
				width: calc(654rpx / 4 - 10rpx);
				height: 100rpx;
			}
		}

		.card_goods_item_title {
			font-weight: 400;
			font-size: 24rpx;
			color: #333333;
			lines: 1;
			overflow: hidden;
			text-overflow: ellipsis;
			text-align: center;
		}

		.card_goods_item_jf {
			flex-direction: row;
			align-items: center;
			justify-content: center;

			.card_goods_item_jf_num {
				font-weight: 400;
				font-size: 28rpx;
				color: #ff9b36;
			}

			.card_goods_item_jf_icon {
				width: 27rpx;
				height: 21rpx;
			}
		}
	}
}

.route_card {
	width: 680rpx;
	flex-direction: row;
	justify-content: center;
	align-items: center;
	margin-bottom: 28rpx;

	.route-item {
		width: 240rpx;
		align-items: center;
		flex-direction: column;

		.route-place {
			font-weight: 400;
			font-size: 32rpx;
			color: #333333;
			white-space: nowrap;
			lines: 1;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.route-location {
			font-weight: 400;
			font-size: 24rpx;
			color: #909599;
			margin-top: 16rpx;
			lines: 1;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}
	}
}

.arrow_img {
	width: 140rpx;
	height: 26rpx;
	margin-left: 30rpx;
	margin-right: 30rpx;
}

/* ====== 高速路况：截图风格时间轴 ====== */
.route-timeline {
	width: 634rpx;
	margin-bottom: 10rpx;
}

.tl-item {
	width: 634rpx;
	flex-direction: row;
}

.tl-left {
	width: 68rpx;
	align-items: center;
}

.tl-dot {
	flex-direction: row;
	align-items: center;
	justify-content: center;
	border-radius: 999rpx;
}

.dot-flag {
	width: 46rpx;
	height: 46rpx;
}

.dot-km {
	width: 60rpx;
	height: 60rpx;
	flex-direction: column;
}

.dot-red {
	background: #ef4519;
}

.dot-orange {
	background: #ff9b36;
}

.dot-green {
	background: #07c07d;
}

.flag-text {
	font-size: 24rpx;
	color: #ffffff;
	font-weight: 600;
}

.km-val {
	font-size: 22rpx;
	color: #ffffff;
	font-weight: 600;
	line-height: 24rpx;
}

.km-unit {
	font-size: 18rpx;
	color: #ffffff;
	line-height: 18rpx;
}

.tl-line {
	flex: 1;
	margin-top: -6rpx;
	margin-bottom: -6rpx;
}

.line-solid {
	width: 24rpx;
	background: #ff9b36;
	border-radius: 999rpx;
}

.line-dotted {
	width: 0;
	border-width: 2rpx;
	border-style: dashed;
	border-color: #ff9b36;
}

.tl-right {
	width: 566rpx;
	padding-left: 18rpx;
	padding-bottom: 26rpx;
}

.tl-head {
	height: 60rpx;
	flex-direction: row;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 12rpx;
}

.tl-title-wrap {
	flex-direction: row;
	align-items: center;
	// flex: 1;
}

.tl-title {
	font-size: 30rpx;
	color: #333333;
	font-weight: 600;
	lines: 1;
	overflow: hidden;
	text-overflow: ellipsis;
	margin-right: 24rpx;
}

.title-danger {
	color: #ff4d4f;
	font-weight: 600;
}

.title-success {
	color: #07c07d;
	font-weight: 600;
}

.tl-sub {
	margin-left: 12rpx;
	font-size: 28rpx;
	color: #333333;
}

.tl-right-text {
	flex-direction: row;
	align-items: center;
}

.tl-right-text1 {
	font-weight: 400;
	font-size: 24rpx;
}

.rt-muted {
	color: #909599;
}

.rt-danger {
	color: #ef4519;
}

.rt-success {
	color: #07c07d;
}

.tl-arrow {
	margin-left: 6rpx;
	font-size: 24rpx;
	color: #909599;
}

.tl-panel {
	border-radius: 16rpx;
}

.rout_box{
		flex: 1;
		background: #EFEFEF;
		border-radius: 12rpx;
		flex-direction: column;
		padding-top: 19rpx;
		padding-right: 20rpx;
		padding-bottom: 19rpx;
		padding-left: 20rpx;
		margin-top: 20rpx;
		.rout_title{
			flex-direction: row;
			align-items: center;
			margin-bottom: 20rpx;
			.rout_img{
				width: 34rpx;
				height: 34rpx;
				margin-right: 10rpx;
			}
			.rout_text{
				font-weight: 500;
				font-size: 24rpx;
				color: #333333;
			}
		}
		.rout_count{
			background: #FFFFFF;
			border-radius: 12rpx;
			padding-top:12rpx;
			padding-bottom: 12rpx;
			padding-left:17rpx;
			padding-right: 17rpx;
			.rout_count_txt{
				font-weight: 400;
				font-size: 24rpx;
				color: #333333;
			}
		}
	}

.tl-panel_scroll {
	flex: 1;
	flex-direction: row;
	justify-content: flex-start;
	white-space: nowrap;
}

.tl-panel-gray {
	background: #efefef;
	padding-top: 16rpx;
	padding-bottom: 16rpx;
	padding-left: 18rpx;
	padding-right: 18rpx;
