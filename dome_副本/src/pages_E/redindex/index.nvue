			if (isLogin.value) {
				res.data.registerPointRule.getPoint = true;
			}
			taskList.value[0].info = res.data.registerPointRule;
			taskList.value[1].info = res.data.bindVehiclePointRule;
			taskList.value[2].info = res.data.completeInfoPointRule;
			getcarlistdata();
		}
	} catch (err) {
