					.lx_info_rinfo_btn_text {
						font-weight: 400;
						font-size: 28rpx;
						color: #ffffff;
						text-align: center;
						line-height: 48rpx;
					}
				}
			}
		}
	}
}

// 接单列表
.card_order {
	width: 654rpx;
