		.rw_item_btn {
			width: 146rpx;
			height: 48rpx;
			background-color: #ff9b36;
			border-radius: 10rpx;

			.rw_item_btn_text {
				text-align: center;
				line-height: 48rpx;
				font-weight: 400;
				font-size: 24rpx;
				color: #ffffff;
