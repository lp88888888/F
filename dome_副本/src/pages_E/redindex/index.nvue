// 逆编码查询当前详情位置
const nowlocationInfo = async (latitude, longitude) => {
	try {
		let res = await DBReverseGeocodingPoi(longitude, latitude);
		console.log('当前位置详细信息', res);
		let name = res.pois.length ? res.pois[0].addr : res.addressComponent.city;
		mylocationinfo.value = {
			name,
			address: res.formatted_address,
			location: {
				longitude: res.location.lng,
				latitude: res.location.lat,
			},
		};
		getcityid({ district: res.addressComponent.district, city: res.addressComponent.city }, 'start');
	} catch (error) {
		console.error('DBReverseGeocodingPoi接口请求出错:', error);
		// 从本地存储获取地址信息
		const address = uni.getStorageSync('address');
		if (address) {
			mylocationinfo.value = {
				name: address.city + addres.district,
				address: address.standardAddress,
				location: {
					longitude: address.lng,
					latitude: address.lat,
				},
			};
			getcityid({ district: address.district, city: address.city }, 'start');
		}
	}
};
