		}

		.router_info_times_2 {
			font-size: 32rpx;
			color: #333333;
		}

		.router_info_times_3 {
			font-size: 28rpx;
			color: #333333;
		}
	}

	.router_info_length {
		width: 702rpx;
		padding-left: 32rpx;
		flex-direction: row;
		flex-wrap: nowrap;
		margin-bottom: 51rpx;

		.router_info_length_item {
			height: 40rpx;
			background: #07c07d;
			border-radius: 8rpx;
			padding-left: 20rpx;
			padding-right: 20rpx;
			margin-right: 20rpx;

			.router_info_length_item_text {
				font-weight: 400;
				font-size: 24rpx;
				color: #ffffff;
				line-height: 40rpx;
			}
		}

		.bg_o {
			background: #ff9b36;
		}
	}

	.router_info_timeline {
		width: 634rpx;

		.timeline_item {
			flex-direction: row;

			.timeline_item_l {
				width: 60rpx;
				margin-right: 24rpx;
				align-items: center;
				position: relative;

				.timeline_item_l_dot {
					width: 60rpx;
					height: 60rpx;
					background: #ff9b36;
					border-radius: 50%;
					align-items: center;
					justify-content: center;
					position: absolute;
					z-index: 2;
				}

				.timeline_item_l_dot_s {
					width: 46rpx;
					height: 46rpx;
					background: #ff9b36;
					border-radius: 50%;
					align-items: center;
					justify-content: center;
					position: absolute;
					z-index: 5;
				}

				.timeline_item_l_line {
					flex: 1;
					width: 24rpx;
					background: #ff9b36;
					margin-top: 5rpx;
				}

				.timeline_item_l_lines {
					flex: 1;
					width: 1rpx;
					margin-top: 5rpx;
					border-left-color: #ff9b36;
					border-left-width: 1rpx;
					border-left-style: dashed;
				}

				.timeline_item_l_dot_text {
					font-size: 24rpx;
					color: #ffffff;
				}

				.timeline_item_l_dot_text1 {
					font-size: 20rpx;
					color: #ffffff;
				}
			}

			.timeline_item_r {
				flex: 1;

				.timeline_item_r_title {
					height: 60rpx;
					margin-bottom: 15rpx;
					flex-direction: row;
					align-items: center;

					.timeline_item_r_title_text {
						font-weight: 500;
						font-size: 28rpx;
						color: #333333;
						margin-right: 24rpx;
					}

					.timeline_item_r_title_weatherimg {
						width: 32rpx;
						height: 32rpx;
						margin-right: 10rpx;
					}

					.timeline_item_r_title_weathertxt {
						font-weight: 400;
						font-size: 28rpx;
						color: #333333;
					}

					.timeline_item_r_title_other {
						flex: 1;
						flex-direction: row;
						align-items: center;
						justify-content: space-between;

						.timeline_item_r_title_other_l {
							flex-direction: row;
							align-items: center;

							.timeline_item_r_title_other_l_txt {
								font-weight: 400;
								font-size: 24rpx;
								color: #909599;
							}

							.timeline_item_r_title_other_l_angle {
							}
						}

						.timeline_item_r_title_other_btn {
							height: 40rpx;
							background: #fd3924;
							border-radius: 8rpx;
							padding-left: 20rpx;
							padding-right: 20rpx;

							.timeline_item_r_title_other_btn_txt {
								font-weight: 400;
								font-size: 24rpx;
								color: #ffffff;
								line-height: 40rpx;
							}
						}
					}
				}

				.timeline_item_r_info {
					background: #efefef;
					border-radius: 12rpx;
					margin-bottom: 49rpx;
					padding-top: 24rpx;
					padding-right: 24rpx;
					padding-bottom: 24rpx;
					padding-left: 24rpx;

					.timeline_item_r_info_etc {
						flex-direction: row;
						align-items: center;

						.timeline_item_r_info_etc_txt {
							width: 96rpx;
							font-weight: 400;
							font-size: 24rpx;
							color: #333333;
							margin-right: 20rpx;
						}

						.timeline_item_r_info_etc_dot {
							flex: 1;
							flex-direction: row;
							align-items: center;

							.timeline_item_r_info_etc_dot_item {
								width: 24rpx;
								height: 24rpx;
								background: #07c07d;
								border-radius: 4rpx;
								margin-right: 10rpx;
							}
						}

						.timeline_item_r_info_etc_time {
							font-weight: 400;
							font-size: 24rpx;
							color: #ef4519;
						}

						.timeline_item_r_info_etc_imgs {
							flex: 1;
							flex-direction: row;
							align-items: center;

							.timeline_item_r_info_etc_imgs1 {
								width: 40rpx;
								height: 40rpx;
								margin-right: 20rpx;
							}
						}

						.timeline_item_r_info_etc_btn {
							height: 40rpx;
							background: #07c07d;
							border-radius: 8rpx;
							padding-left: 20rpx;
							padding-right: 20rpx;

							.timeline_item_r_info_etc_btn_txt {
								font-weight: 400;
								font-size: 24rpx;
								color: #ffffff;
								line-height: 40rpx;
							}
						}
					}
				}
			}
		}
	}

	.router_go_btn {
		width: 498rpx;
		height: 88rpx;
		border-radius: 18rpx;
		border-width: 2rpx;
		border-style: solid;
		border-color: #fd3924;
		margin-top: 45rpx;
		margin-bottom: 40rpx;

		.router_go_btn_text {
			font-weight: 500;
			font-size: 28rpx;
			color: #fd3924;
			text-align: center;
			line-height: 88rpx;
		}
	}
}

/* 九宫格 (替换为 Flex) */
.grid-box {
	width: 702rpx;
	/* 690 - 30*2 */
	flex-direction: row;
	justify-content: flex-start;
	/* 使用 space-around 模拟 grid-gap */
	flex-wrap: wrap;

	.grid-box-item {
		flex-direction: column;
		align-items: center;
		justify-content: center;
		// margin-left: 15rpx;
		// margin-right: 15rpx;
		margin-bottom: 32rpx;

		.grid-box-img {
			width: 100rpx;
			height: 100rpx;
			margin-bottom: 10rpx;
		}

		.grid-box-text {
			font-weight: 400;
			font-size: 24rpx;
			color: #333333;
			word-break: keep-all;
		}
	}
}

// 旅行信息
.card_lx {
	width: 702rpx;
	height: 248rpx;
	background-image: linear-gradient(to bottom right, #ebf8ee, #fefefe);
	box-shadow: 0rpx 2rpx 8rpx 0rpx #d3e7d1;
	border-radius: 32rpx;
	flex-direction: column;
	align-items: center;

	.lx_info {
		width: 654rpx;
		flex-direction: row;
		justify-content: space-between;

		.lx_info_img {
			width: 200rpx;
			height: 156rpx;
			margin-right: 20rpx;
		}

		.lx_info_texts {
			flex: 1;
			height: 156rpx;
			justify-content: space-between;

			.lx_info_title {
				font-weight: 400;
				font-size: 28rpx;
				color: #333333;
			}

			.lx_info_time {
				font-weight: 400;
				font-size: 24rpx;
				color: #6e6e6e;
			}

			.lx_info_rinfo {
				flex-direction: row;
				align-items: center;
				justify-content: space-between;

				.lx_info_rinfo_text {
					font-weight: 400;
					font-size: 24rpx;
					color: #6e6e6e;
				}

				.lx_info_rinfo_text1 {
