// 任务列表
.rw_list {
	.rw_item {
		width: 654rpx;
		height: 88rpx;
		background-image: linear-gradient(to right, #ffdede, #fefefe);
		border-radius: 16rpx;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding-left: 20rpx;
		padding-right: 28rpx;
		position: relative;
		margin-bottom: 29rpx;
		border-bottom-width: 3rpx;
		border-bottom-style: solid;
		border-bottom-color: #fd7061;

		&:last-child {
			margin-bottom: 0;
		}

		.rw_item_img {
			width: 76rpx;
			height: 76rpx;
			margin-right: 20rpx;
		}

		.rw_item_text {
			flex: 1;
			text-align: left;
			font-weight: 400;
			font-size: 28rpx;
			color: #333333;
