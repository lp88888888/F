const getNewsListFun = async () => {
	let params = {
		pageNum: 1,
		pageSize: 20,
		type: 'HEADLINE',
		userId: uni.getStorageSync('userInfo').id,
	};
	const res = await getNewsList(params);
	if (res?.code == '0') {
		newArray.value = res.page.records.map((item) => item.title);
	}
};
