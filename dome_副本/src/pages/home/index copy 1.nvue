								font-size: 24rpx;
								color: #333333;
								margin-right: 20rpx;
							}

							.timeline_item_r_info_etc_dot {
								flex: 1;
								flex-direction: row;
								align-items: center;

								.timeline_item_r_info_etc_dot_item {
									width: 24rpx;
