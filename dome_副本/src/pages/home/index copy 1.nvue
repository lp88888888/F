	.tl-item {
		width: 634rpx;
		flex-direction: row;
	}

	.tl-left {
		width: 68rpx;
		align-items: center;
	}

	.tl-dot {
		flex-direction: row;
		align-items: center;
		justify-content: center;
		border-radius: 999rpx;
	}

	.dot-flag {
		width: 46rpx;
		height: 46rpx;
	}

	.dot-km {
		width: 60rpx;
		height: 60rpx;
		flex-direction: column;
	}

	.dot-red {
		background: #ef4519;
	}

	.dot-orange {
		background: #ff9b36;
	}

	.dot-green {
		background: #07c07d;
	}

	.flag-text {
		font-size: 24rpx;
		color: #ffffff;
		font-weight: 600;
	}

	.km-val {
		font-size: 22rpx;
		color: #ffffff;
		font-weight: 600;
		line-height: 24rpx;
	}

	.km-unit {
		font-size: 18rpx;
		color: #ffffff;
		line-height: 18rpx;
	}

	.tl-line {
		flex: 1;
		margin-top: -6rpx;
		margin-bottom: -6rpx;
	}

	.line-solid {
		width: 24rpx;
		background: #ff9b36;
		border-radius: 999rpx;
	}

	.line-dotted {
		width: 0;
		border-width: 2rpx;
