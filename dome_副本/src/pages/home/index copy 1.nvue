	const to1Decimal = (v : any) : number => {
		const n = Number(v);
		return Number.isFinite(n) ? Number(n.toFixed(1)) : 0;
	};
	// 从字符串里提取数字（如 “12.3km”）
	const extractTo1Decimal = (v : any) : number => {
		if (v == null) return 0;
		if (typeof v === 'number') return to1Decimal(v);
		const m = String(v).match(/-?\d+(\.\d+)?/);
		return m ? to1Decimal(m[0]) : 0;
	};

