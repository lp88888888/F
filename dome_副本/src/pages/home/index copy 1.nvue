	/* ==================== 主内容区 ==================== */
	.page-view {
		position: relative;
		z-index: 2;
		padding-left: 24rpx;
		padding-right: 24rpx;
		flex-direction: column;
		margin-top: 20rpx;
	}

	.card {
		width: 702rpx;
		/* 750 - 30*2 */
		border-radius: 32rpx;
		flex-direction: column;
		background-image: linear-gradient(to top left, #ebf8ee, #fefefe);
		// box-shadow: 0rpx 2rpx 8rpx 0rpx var(--label-color);
		margin-bottom: 32rpx;
	}

	// card新渐变色
	.card1 {
		background-image: linear-gradient(to right, #ebf8ee, #fefefe);
	}

	.card_icon_card_header {
		width: 702rpx;
		flex-direction: row;
		justify-content: space-between;
		padding-right: 24rpx;

		.card_icon_card_header_lt {
			position: relative;
			width: 230rpx;
			height: 74rpx;
			flex-direction: row;
			align-items: flex-start;
			justify-content: center;
			padding-top: 8rpx;

			.card_icon_card_header-img {
				width: 230rpx;
				height: 74rpx;
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
			}

			.title_text_primary {
				font-family: DingTalk, DingTalk;
				font-weight: normal;
				font-size: 32rpx;
				color: #ffffff;
			}

			.card_title_icon {
				width: 16rpx;
				height: 16rpx;
				margin-left: 8rpx;
			}
		}

		.card_icon_card_header_rt_map {
