	const maskPhone = (raw) => {
		if (!raw) return ''
		const clean = String(raw).replace(/\D/g, '')
		if (clean.length === 11 && /^1[3-9]/.test(clean)) {
			return clean.replace(/(\d{3})\d{4}(\d{4})/, '$1****$2')
		}
		return raw // 或 return '***'
	}
