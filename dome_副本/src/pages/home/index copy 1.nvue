	/* ==================== 基础样式重置与工具类 ==================== */
	.page-container {
		width: 750rpx;
		min-height: 100vh;
		/* background: #F5F5F4; nvue 不支持 transparent */
		flex-direction: column;
		align-items: center;
	}

	.m-t-40 {
		margin-top: 40rpx;
	}

	.m-t-20 {
		margin-top: 20rpx;
	}

	.m-t-10 {
		margin-top: 10rpx;
	}

	.m-b-30 {
		margin-bottom: 30rpx;
	}

	.m-b-20 {
		margin-bottom: 20rpx;
	}

	.m-b-15 {
		margin-bottom: 15rpx;
	}

	.fs-24 {
		font-size: 24rpx;
	}

	.col3 {
		color: #333333;
	}

	.col6 {
		color: #666666;
	}

	.fw-400 {
		font-weight: 400;
	}

	/* Flex 快捷类 */
	.fl-ce-ce {
		flex-direction: row;
		align-items: center;
		justify-content: center;
	}

	.flex {
		flex-direction: row;
	}

	.flex-col {
		flex-direction: column;
	}

	.ali-cen {
		align-items: center;
	}

	.fl-ce-sb {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
	}

	/* 文本截断（nvue 仅支持单行省略） */
	.tex-no-wrap {
		/* nvue 的单行文本溢出处理 */
		lines: 1;
		text-overflow: ellipsis;
	}

	/* nvue 无法实现多行文本省略，只能保证容器高度 */
	.g-line2,
	.s-line2 {
		lines: 2;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* ==================== 顶部导航 ==================== */
	.nav-container {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		// background-image: linear-gradient(to bottom, #edfcf0, #fcfffc);
