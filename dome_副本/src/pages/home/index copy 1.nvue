								background: #628f2f;
								border-radius: 8rpx;
								padding-left: 20rpx;
								padding-right: 20rpx;

								.timeline_item_r_title_other_btn_txt {
									font-weight: 400;
									font-size: 24rpx;
									color: #ffffff;
									line-height: 40rpx;
								}
							}
						}
					}

					.timeline_item_r_info {
						background: #efefef;
						border-radius: 12rpx;
						margin-bottom: 49rpx;
						padding-top: 24rpx;
						padding-right: 24rpx;
						padding-bottom: 24rpx;
						padding-left: 24rpx;

						.timeline_item_r_info_etc {
							flex-direction: row;
							align-items: center;

							.timeline_item_r_info_etc_txt {
								width: 96rpx;
