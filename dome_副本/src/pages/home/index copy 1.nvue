								.timeline_item_r_info_etc_btn_txt {
									font-weight: 400;
									font-size: 24rpx;
									color: #ffffff;
									line-height: 40rpx;
								}
							}
						}
					}
				}
			}
		}

		.router_go_btn {
			width: 498rpx;
