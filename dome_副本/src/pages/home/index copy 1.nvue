	};



	const swiperHeight = ref(500); // 有底部的预估高度 480，无底部预估 260，可根据实际UI微调
	const swiperCurrent = ref(0);
	const hasBottomData = (item : any) => {
		let num = 0
		if (item.serviceAreaActivityList && item.serviceAreaActivityList.length) {
			num++
		}
		if (item.gasStationList && item.gasStationList.length) {
			num++
		}
		if (item.chargingStationList && item.chargingStationList.length) {
			num++
		}
		return num
		// return (item.serviceAreaActivityList && item.serviceAreaActivityList.length) || (item.gasStationList && item.gasStationList.length) ||(item.chargingStationList && item.chargingStationList.length)
	};
	const handleSwiperChange = (e : any) => {
		const currentIdx = e.detail.current;
		swiperCurrent.value = e.detail.current
		const currentItem = serviceInfoList.value[currentIdx];
		let targetHeight = 290; // 基础高度
		if (hasBottomData(currentItem) == 3) {
			targetHeight = 500; // 展开时的高度
		} else if (hasBottomData(currentItem) == 2) {
			targetHeight = 400; // 展开时的高度
		} else if (hasBottomData(currentItem) == 1) {
			targetHeight = 315; // 展开时的高度
		} else {
			targetHeight = 290; // 只有头部信息时的高度 (建议根据设计稿实际高度调整)
		}
		nextTick(() => {
			swiperHeight.value = targetHeight
		})
	};
	/* -------------start--------------数字人初始化-------------start-------------- */
	const bdDigitalMan = ref(null);
	const initMan = (isStok : boolean = true) => {
		/*
		cameraId:  全身=v_full_cam,半身=v_half_cam,上半身=h_shoulder_cam，脸部=h_face_cam
		*/
		bdDigitalMan.value.initBdDigitalMan(
			JSON.stringify({
				hairId: 'coco_02_hair_out', //头发
				badgeId: 'coco_02_badge_out', //眼镜
				bodyId: 'coco_02_body_out',
				shoesId: 'coco_02_shoes_out',
				cameraId: 'v_half_cam',
				speechPersonId: 'LITE_clever_boy',
				speechSpeed: 10,
				// speechPitch:5,
				isAutoAnimoji: true,
			}),
			(res) => {
				console.log('4567890', res);
				res = JSON.parse(res);
				if (res.code == 2) {
					// setTimeout(()=>{
					// 	stokValue(chatStore.helloText)
					// },1000)
				}
			}
		);
	};

	/* -------------start--------------大模型请求-------------start-------------- */
	const chatSSEClientRef = ref(null);
	const answerText = ref('');
	const qureyShow = ref(true);
	const chatCot = ref([]);
	const queryTextName = computed(() => {
		return (cot) => {
			let title = '大模型';
			console.log();
			if (cot && Array.isArray(cot) && cot.length) {
				if (cot[0].outputs) {
					title = cot[0].outputs.name;
				}
			}
			return title;
		};
	});
	const setChat = async (query) => {
		answerText.value = '';
		qureyShow.value = true;
		chatCot.value = [];
		const requestTime = formatTimestamp(new Date().getTime() - 1000, 'YYYY-MM-DD HH:mm:ss');
		console.log('requestTime', requestTime);
		try {
			const tokenRes = await getOpenToken(requestTime);
			if (tokenRes.status === 200) {
				start(tokenRes.result, requestTime, query);
			} else {
				toast(tokenRes.message);
			}
			console.log('-----tokenRes-->', tokenRes);
		} catch (e) {
			console.log('------->', e);
			toast(e.message);
		}
	};
	const start = (token, requestTime, query) => {
		console.log('----0-0--start---0-00--0-0');
		// const messageId = getUUID()
		try {
			let params = {
				isAutoSpeech: false,
				playType: 1,
				url: aiUrl + '/copilot/v1/openApi/chat',
				copilotAk: 'copilot_ak_4qZ84MGWrRoXcMwY',
				assistantId: '118',
				requestTime: requestTime,
				copilotToken: token,
				"removeRegularList":chatStore.removeRegularList,
				"ttsConfig": chatStore.ttsConfig,
				"endWidthSymbol":chatStore.endWidthSymbol,
				body: JSON.stringify({
					type: 'IM_CLICK',
					assistantId: 118,
					query: query,
					sessionId: getUUID(),
					// skillId:skillData.value.skill_id || undefined,
					
					
					params: {
						userCode: getToken(), // 用户token
						// 'user_info': formData.value || undefined,
						userLat: uni.getStorageSync('address').lat || '',
						userLon: uni.getStorageSync('address').lng || '',
						useLon: uni.getStorageSync('address').lng || '',
						member_id: uni.getStorageSync('userInfo').id || '',
						"originLat":mylocationinfo.value.location?.latitude,//起始点纬度
						"originLon":mylocationinfo.value.location?.longitude,//起始点经度
						"desLat":endlocationinfo.value.location?.latitude,//终点纬度
						"desLon":endlocationinfo.value.location?.longitude,//终点经度
						// 'member_id':'131',
						// 'memberType': uni.getStorageSync('userInfo').memberType || '1',
						// mobile:parseTokens(uni.getStorageSync('Token'))?.member_phone,
					},
				}),
			};
			console.log('--0-0-params1', JSON.parse(params.body));
			bdDigitalMan.value.requestBdLargeModelData(params, (res) => {
				let data = JSON.parse(JSON.parse(res).data);
				// console.log('模型返回-->', data);
				chatCot.value = data.data.cot;
				if (data.code == 100) {
					answerText.value = answerText.value + (data.data.answer || '');
				} else {
					answerText.value = data.data.answer;
					qureyShow.value = false;

					// 停止播放
					// bdDigitalMan.value.bdDigitalManSpeechInterrupt((event) => { });
				}
			});
		} catch (err) {
			console.log('111111111111111111-----------', err);
		}
		bdDigitalMan.value.bdDigitalManSubtitlesCallback((event)=>{
			console.log('-开始--bdDigitalManSpeechComplete---');
			bobaoShow.value = true
		})
		bdDigitalMan.value.bdDigitalManSpeechComplete((res)=>{
			recognizer.start();
			console.log('-结束--bdDigitalManSpeechComplete---');
			bobaoShow.value = false
		})
	};
	const bobaoShow = ref(false);
	const startTalk = ()=>{
		bobaoShow.value = false;
		bdDigitalMan.value.bdDigitalManSpeechInterrupt(event=>{
			console.log('-------打断讲话-------',event);
		})
	}
	// 开始播报
	const stokValue = (text)=>{
		bdDigitalMan.value.bdDigitalManSpeech({
			  ttsConfig: chatStore.ttsConfig,
			  "content": text,
			  "regularList": chatStore.regularList
		},(datas)=>{
			bobaoShow.value = true
		});
		bdDigitalMan.value.bdDigitalManSpeechComplete((res)=>{
			recognizer.start();
			bobaoShow.value = false
		})
	}
	/* -------------end--------------大模型请求-------------end-------------- */
	// 收费站信息查询
	// const getList = async () => {
	// 	const params = {
	// 		latitude: latitude.value,
	// 		longitude: longitude.value,
