			lines: 1;
			white-space: nowrap;
			text-overflow: ellipsis;
		}

		.action-cards {
			flex: 1;
			// flex-direction: row;
		}

		.cardd {
			width: 600rpx;
			padding: 20rpx;
			border-radius: 16rpx;
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			margin-top: 20rpx;

			.iconK {
				color: #47DFDA;
				background-color: #EAFFFF;
				border: 2rpx solid #47DFDA;

				&-text {
					color: #fff;
					background-color: #47DFDA;
				}
