	// 查询天气
	const getcityid = async (e, type) => {
		let params = {
			locationNameZh: e.district,
			adm2NameZh: e.city,
		};
		const response = await getLocationInfoid(params);
		if (response.code == 200) {
			const params1 = {
				key: 'c378003293184af18adad854cc0c12bc',
				location: response.data.locationId,
				lang: 'zh-hans',
				unit: 'm',
			};
			const params2 = {
				location: response.data.locationId,
			};
			const response2 : any = await getWeatherWarnings(params2);
			weatherNowyujing.value = response2.data.alerts || [];
			const response1 = await getTadayApi(params1);
			console.log('获取的天气数据', type, response1);
			if (type == 'now') {
				weatherNow.value = response1.now;
				getBannerList();
				uni.setStorageSync('locationId', response.data.locationId);
			}
			if (type === 'start') startWeatherNow.value = response1.now;
			if (type === 'end') endWeatherNow.value = response1.now;
		}
	};
