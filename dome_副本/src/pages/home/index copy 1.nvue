		}
		if (item.locationDirection) {
			return `(${item.serviceAreaName.indexOf('绕城') != -1 ? ['', '内环', '外环'][item.locationDirection] : ['', '上行', '下行'][item.locationDirection]
				})`;
		}
		return '';
	};
