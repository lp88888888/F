		margin-top: 24rpx;
	}

	// 导航信息
	.router_info {
		flex-direction: column;
		align-items: center;

		.router_info_times {
			width: 702rpx;
			flex-direction: row;
			align-items: flex-end;
			padding-left: 32rpx;
			margin-bottom: 24rpx;

			.router_info_times_1 {
				font-weight: 500;
				font-size: 36rpx;
				color: #333333;
			}

			.router_info_times_2 {
				font-size: 32rpx;
				color: #333333;
			}

			.router_info_times_3 {
				font-size: 28rpx;
				color: #333333;
			}
		}

		.router_info_length {
			width: 702rpx;
			padding-left: 32rpx;
			flex-direction: row;
			flex-wrap: nowrap;
			margin-bottom: 51rpx;

			.router_info_length_item {
				height: 40rpx;
				background: #07c07d;
				border-radius: 8rpx;
				padding-left: 20rpx;
				padding-right: 20rpx;
				margin-right: 20rpx;

				.router_info_length_item_text {
					font-weight: 400;
					font-size: 24rpx;
					color: #ffffff;
					line-height: 40rpx;
