	// 客车聚合点
	const showMapPoint = async () => {
		if (vehicleType.value == 1) return;
		let address = uni.getStorageSync('address');
		console.log('------------showMapPoint-----------------------');
		try {
			let params = {
				types: [1, 2, 6, 7],
				keyWord: '',
				longitude: address.lng,
				latitude: address.lat,
				centerLat: address.lat,
				centerLng: address.lng,
				zoom: 11,
				coordType: 2,
				containerW: 350,
				containerH: 170,
			};
			console.log('------------showMapPoint-----------------------', vehicleType.value != 1);
			console.log('------------showMapPoint-----------------------', bdMapViewRef.value);
			if (vehicleType.value != 1 && bdMapViewRef.value) {
				const res = await postmapServicesList(params);
				console.log('-----------------------------------', res);
				console.log('-----------------------------------', params);
				if (res.data.clusters.length) {
					let hasList = [];
					for (let i in res.data.clusters) {
						hasList = [...hasList, ...res.data.clusters[i].points];
					}
					markers.value = hasList.map((item, index) => {
						item.width = '27';
						item.stationName = item.name;
						item.height = '32';
						item.latitude = Number(item.latitude);
						item.longitude = Number(item.longitude);
						item.iconPath = getIconPathByType(item);
						item.logoUrl = getIconPathByType(item);
						return item;
					});
					console.log(markers.value);
					setTimeout(() => {
						bdMapViewRef.value.showMapPoint(JSON.stringify(markers.value), (event) => {
							console.log('-----------首页聚合点回调-----------', event);
						});
					}, 100);
				} else {
					// 清除描点
					// bdMapViewRef.value.removeMapPoint('',event=>{})
				}
			}
		} catch (err) {
			console.log('-0-0-0-0--0-', err);
		}
		// nextTick(() => {
		// 	if (vehicleType.value != 1 && bdMapViewRef.value) {
		// 		bdMapViewRef.value.showMapPoint(JSON.stringify(markers.value), (event) => {
